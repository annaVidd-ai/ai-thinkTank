// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client-js"
}

model AgentTask {
  id        String   @id @default(uuid())
  type      String   // SCOUT | ORCHESTRATE | WEAVER_SWEEP | SCOUT_NARRATIVE | DEBATE_ANALYST | DEBATE_SKEPTIC | ANALYZE | SCORE | MAP
  status    String   // "PENDING", "PROCESSING", "COMPLETED", "FAILED"
  payload   String   // JSON
  result    String?  // JSON
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Cluster {
  id        String         @id @default(uuid())
  assetId   String                   // Neo4j canonical id — multiple rows allowed (one per investigation)
  assetType String                   // e.g. "Repository", "SmartContract"
  status    String         @default("DETECTED") // "DETECTED", "NARRATIVE_SCOUTING", "DEBATING", "SCORED"
  createdAt DateTime       @default(now())
  debates   Debate[]
  scores    ClusterScore[]
  alert     Alert?
}

model ScoringConfig {
  id              String          @id @default(uuid())
  name            String
  weights         String                   // JSON: {"signalStrength": 0.40, "timing": 0.35, "upside": 0.25}
  isActive        Boolean         @default(false)
  scores          ClusterScore[]
  backtestResults BacktestResult[]
}

model BacktestCase {
  id             String           @id @default(cuid())
  ticker         String           @unique
  projectAlias   String           // e.g., "Project_Alpha" for blinded runs
  sector         String           // e.g., "L1", "DeFi", "Infrastructure"
  signalDate     DateTime         // when early momentum signal would have fired
  signalPrice    Float            // price at signal date
  athPrice       Float            // all-time high price
  actualMultiple Float            // athPrice / signalPrice
  split          String           // "calibration" | "validation" | "verification"
  blinded        Boolean          @default(false)
  isControl      Boolean          @default(false) // true = negative control case
  createdAt      DateTime         @default(now())

  results        BacktestResult[]
}

model BacktestResult {
  id            String        @id @default(cuid())
  caseId        String
  configId      String
  runType       String        // "blinded" | "unblinded"
  runIndex      Int           // which run (1-3) for N=3 median
  signalStrength Float
  timing        Float
  upside        Float
  totalScore    Float
  verdict       String?       // debate verdict
  variance      Float?        // populated after N=3 runs complete
  createdAt     DateTime      @default(now())

  case          BacktestCase  @relation(fields: [caseId], references: [id])
  config        ScoringConfig @relation(fields: [configId], references: [id])
}

model ClusterScore {
  id         String        @id @default(uuid())
  clusterId  String
  cluster    Cluster       @relation(fields: [clusterId], references: [id], onDelete: Cascade)
  configId   String
  config     ScoringConfig @relation(fields: [configId], references: [id])
  totalScore Float
  breakdown  String                 // JSON
  createdAt  DateTime      @default(now())
}

model Alert {
  id         String   @id @default(uuid())
  clusterId  String   @unique        // one alert per cluster investigation
  cluster    Cluster  @relation(fields: [clusterId], references: [id], onDelete: Cascade)
  ticker     String
  totalScore Float
  thesis     String
  createdAt  DateTime @default(now())
}

model Debate {
  id               String          @id @default(uuid())
  clusterId        String
  cluster          Cluster         @relation(fields: [clusterId], references: [id], onDelete: Cascade)
  status           String          @default("IN_PROGRESS") // "IN_PROGRESS", "COMPLETED", "ESCALATED"
  currentRound     Int             @default(1)
  verdict          String?
  narrativeContext String?         // Summary from SCOUT_NARRATIVE step; used for SCORE context
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  messages         DebateMessage[]
}

model DebateMessage {
  id        String   @id @default(uuid())
  debateId  String
  debate    Debate   @relation(fields: [debateId], references: [id], onDelete: Cascade)
  role      String   // "ANALYST", "SKEPTIC"
  content   String   // JSON
  round     Int
  createdAt DateTime @default(now())
}